{
	"name": "@takashi145/md-quiz",
	"version": "0.2.0",
	"description": "Generate interactive quizzes from Markdown.",
	"type": "module",
	"main": "./dist/md-quiz.js",
	"module": "./dist/md-quiz.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/md-quiz.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"keywords": [
		"markdown",
		"quiz"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/takashi145/md-quiz.git"
	},
	"bugs": {
		"url": "https://github.com/takashi145/md-quiz/issues"
	},
	"homepage": "https://github.com/takashi145/md-quiz#readme",
	"scripts": {
		"dev": "vite",
		"build": "vite build && tsc --emitDeclarationOnly",
		"build:docs": "vite build --config vite.docs.config.ts",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"typescript": "^5.4.0",
		"vite": "^5.2.0",
		"vite-plugin-dts": "^3.9.0"
	}
}
